{
  "name": "job-application-tracker",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm run -ws build",
    "lint": "npm run -ws lint",
    "test": "npm run -ws test"
  }
}